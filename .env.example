# Public site under test
SITE_URL=https://www.openbrewerydb.org

# Public API under test
API_URL=https://api.openbrewerydb.org

# --- Optional: add a custom location alongside the curated set -----------
# The suite always tests a curated set of US + international locations
# defined in src/config/locations.ts. Setting USER_LATITUDE + USER_LONGITUDE
# below adds a 9th "Custom (env)" location to the run; leaving them blank
# (or removing them) tests only the curated set.
#
# When set, the value of `cities` may be a comma-separated list. Leave it
# empty to skip the city assertion (country-only matching, like Seoul).
USER_LATITUDE=
USER_LONGITUDE=
USER_COUNTRY=
USER_CITIES=
MAX_DISTANCE_KM=40
NEAREST_COUNT=5
USER_LOCATION_NAME=

# --- Parallelism --------------------------------------------------------
# Override Playwright's worker count. Defaults to 5 (matches the suite's
# "4-5 parallel agents" target).
# PLAYWRIGHT_WORKERS=5
