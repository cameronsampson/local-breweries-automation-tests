# Public site under test
SITE_URL=https://www.openbrewerydb.org

# Public API under test
API_URL=https://api.openbrewerydb.org

# --- Your reference location ---------------------------------------------
# Coordinates are used to query the API with by_dist=lat,lng and to compute
# distances locally with the haversine formula.
USER_LATITUDE=37.7749
USER_LONGITUDE=-122.4194

# Country and city the 5 nearest breweries are expected to match.
# Country must match exactly (e.g. "United States").
# City: comma-separated list of acceptable cities. Use a single value for
# strict matching, or list nearby municipalities if your area spans them.
USER_COUNTRY=United States
USER_CITIES=San Francisco

# Maximum search radius in kilometers (the spec asks for 40).
MAX_DISTANCE_KM=40

# How many nearest breweries to assert on.
NEAREST_COUNT=5
